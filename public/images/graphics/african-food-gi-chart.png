<svg xmlns="http://www.w3.org/2000/svg" width="900" height="700" viewBox="0 0 900 700">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#064e3b" />
      <stop offset="100%" style="stop-color:#065f46" />
    </linearGradient>
    <pattern id="dots" width="30" height="30" patternUnits="userSpaceOnUse">
      <circle cx="15" cy="15" r="1.5" fill="white" opacity="0.08"/>
    </pattern>
  </defs>
  <rect width="900" height="700" fill="url(#g)"/>
  <rect width="900" height="700" fill="url(#dots)"/>
  <text x="450" y="336" font-family="Georgia, serif" font-size="18" font-weight="600" fill="#ffffff" text-anchor="middle" opacity="0.9">African Food</text>
  <text x="450" y="364" font-family="Georgia, serif" font-size="18" font-weight="600" fill="#ffffff" text-anchor="middle" opacity="0.9">Glycemic Index Chart</text>
  <text x="450" y="680" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle" opacity="0.5">Vieve Health &amp; Wellness</text>
</svg>