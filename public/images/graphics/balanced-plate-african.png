<svg xmlns="http://www.w3.org/2000/svg" width="800" height="800" viewBox="0 0 800 800">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#064e3b" />
      <stop offset="100%" style="stop-color:#065f46" />
    </linearGradient>
    <pattern id="dots" width="30" height="30" patternUnits="userSpaceOnUse">
      <circle cx="15" cy="15" r="1.5" fill="white" opacity="0.08"/>
    </pattern>
  </defs>
  <rect width="800" height="800" fill="url(#g)"/>
  <rect width="800" height="800" fill="url(#dots)"/>
  <text x="400" y="372" font-family="Georgia, serif" font-size="18" font-weight="600" fill="#ffffff" text-anchor="middle" opacity="0.9">Balanced African</text>
  <text x="400" y="400" font-family="Georgia, serif" font-size="18" font-weight="600" fill="#ffffff" text-anchor="middle" opacity="0.9">Plate Graphic</text>
  <text x="400" y="428" font-family="Georgia, serif" font-size="18" font-weight="600" fill="#ffffff" text-anchor="middle" opacity="0.9">(Design Needed)</text>
  <text x="400" y="780" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle" opacity="0.5">Vieve Health &amp; Wellness</text>
</svg>